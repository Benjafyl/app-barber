NODE_ENV=production
APP_HOST=appbarber.cl
APP_URL=https://appbarber.cl
DATABASE_URL=postgresql://barber_user:replace-with-a-long-password@postgres:5432/barber_db?schema=public
POSTGRES_DB=barber_db
POSTGRES_USER=barber_user
POSTGRES_PASSWORD=replace-with-a-long-password
BETTER_AUTH_SECRET=replace-with-a-random-32-character-minimum-secret
BETTER_AUTH_URL=https://appbarber.cl
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASSWORD=password
SMTP_FROM=no-reply@appbarber.cl
UPLOADS_DIR=/app/uploads
TZ=America/Santiago

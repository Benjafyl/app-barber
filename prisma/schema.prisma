generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  BARBERSHOP_ADMIN
  BARBER
}

enum BookingStatus {
  RESERVED
  PENDING_CONFIRMATION
  CONFIRMED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_BARBER
  NO_SHOW
  COMPLETED
  PAID
  PAYMENT_PENDING
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  OTHER
}

enum IncomeSource {
  SERVICE
  RENT
  MANUAL
}

enum ExpenseCategory {
  SUPPLIES
  TOOLS
  RENT
  UTILITIES
  MARKETING
  MAINTENANCE
  OTHER
}

enum RentStatus {
  CURRENT
  PENDING
  OVERDUE
  PARTIAL
  PAID
}

enum RentPeriodicity {
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SMS
  INTERNAL
}

enum AvailabilityBlockType {
  WORKING_HOURS
  BREAK
  TIME_OFF
  MANUAL_BLOCK
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  emailVerified Boolean            @default(false)
  image         String?
  role          UserRole           @default(BARBER)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  accounts      Account[]
  sessions      Session[]
  barber        Barber?
  memberships   BarbershopMember[]
  expenses      Expense[]          @relation("ExpenseCreator")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Barbershop {
  id                   String              @id @default(cuid())
  name                 String
  slug                 String              @unique
  description          String?
  address              String?
  phone                String?
  email                String?
  imageUrl             String?
  timezone             String              @default("America/Santiago")
  minimumBookingNotice Int                 @default(60)
  cancellationNotice   Int                 @default(120)
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  members              BarbershopMember[]
  barbers              Barber[]
  clients              Client[]
  services             Service[]
  bookings             Booking[]
  expenses             Expense[]
  supplies             Supply[]
  tools                Tool[]
  rentAgreements       RentAgreement[]
  availabilityBlocks   AvailabilityBlock[]

  @@map("barbershops")
}

model BarbershopMember {
  id           String     @id @default(cuid())
  userId       String
  barbershopId String
  role         UserRole
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([userId, barbershopId])
  @@index([barbershopId, role])
  @@map("barbershop_members")
}

model Barber {
  id           String              @id @default(cuid())
  userId       String              @unique
  barbershopId String
  slug         String              @unique
  publicName   String
  bio          String?
  imageUrl     String?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershop   Barbershop          @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  services     BarberService[]
  bookings     Booking[]
  completed    CompletedService[]
  expenses     Expense[]
  agreements   RentAgreement[]
  blocks       AvailabilityBlock[]

  @@index([barbershopId, isActive])
  @@map("barbers")
}

model Client {
  id                String     @id @default(cuid())
  barbershopId      String
  name              String
  phone             String
  instagram         String?
  email             String?
  notes             String?
  firstBookingAt    DateTime   @default(now())
  lastAppointmentAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  barbershop        Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  bookings          Booking[]

  @@unique([barbershopId, phone])
  @@index([barbershopId, name])
  @@map("clients")
}

model Service {
  id              String          @id @default(cuid())
  barbershopId    String
  name            String
  description     String?
  price           Decimal         @db.Decimal(12, 2)
  durationMinutes Int
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  barbershop      Barbershop      @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barberServices  BarberService[]
  bookings        Booking[]

  @@index([barbershopId, isActive])
  @@map("services")
}

model BarberService {
  barberId  String
  serviceId String
  createdAt DateTime @default(now())
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
  @@map("barber_services")
}

model Booking {
  id               String            @id @default(cuid())
  barbershopId     String
  barberId         String
  clientId         String
  serviceId        String
  startsAt         DateTime
  endsAt           DateTime
  status           BookingStatus     @default(RESERVED)
  quotedPrice      Decimal           @db.Decimal(12, 2)
  customerToken    String            @unique @default(cuid())
  customerNote     String?
  internalNote     String?
  confirmedAt      DateTime?
  cancelledAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  barbershop       Barbershop        @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber           Barber            @relation(fields: [barberId], references: [id], onDelete: Restrict)
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  service          Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  completedService CompletedService?
  notifications    NotificationLog[]

  @@index([barberId, startsAt])
  @@index([barbershopId, startsAt])
  @@index([clientId, startsAt])
  @@map("bookings")
}

model CompletedService {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  barberId       String
  completedAt    DateTime @default(now())
  actualDuration Int?
  servicePrice   Decimal  @db.Decimal(12, 2)
  note           String?
  createdAt      DateTime @default(now())
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  barber         Barber   @relation(fields: [barberId], references: [id], onDelete: Restrict)
  payment        Payment?

  @@index([barberId, completedAt])
  @@map("completed_services")
}

model Payment {
  id                 String            @id @default(cuid())
  completedServiceId String?           @unique
  status             PaymentStatus     @default(PENDING)
  method             PaymentMethod?
  source             IncomeSource      @default(SERVICE)
  amount             Decimal           @db.Decimal(12, 2)
  paidAt             DateTime?
  reference          String?
  note               String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  completedService   CompletedService? @relation(fields: [completedServiceId], references: [id], onDelete: SetNull)
  rentPayment        RentPayment?

  @@index([status, paidAt])
  @@map("payments")
}

model Expense {
  id           String          @id @default(cuid())
  barbershopId String?
  barberId     String?
  createdById  String
  category     ExpenseCategory
  amount       Decimal         @db.Decimal(12, 2)
  description  String
  occurredAt   DateTime        @default(now())
  receiptUrl   String?
  createdAt    DateTime        @default(now())
  barbershop   Barbershop?     @relation(fields: [barbershopId], references: [id], onDelete: SetNull)
  barber       Barber?         @relation(fields: [barberId], references: [id], onDelete: SetNull)
  createdBy    User            @relation("ExpenseCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([barbershopId, occurredAt])
  @@index([barberId, occurredAt])
  @@map("expenses")
}

model Supply {
  id           String     @id @default(cuid())
  barbershopId String
  name         String
  currentStock Decimal?   @db.Decimal(12, 2)
  unit         String?
  minimumStock Decimal?   @db.Decimal(12, 2)
  unitCost     Decimal?   @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@index([barbershopId, name])
  @@map("supplies")
}

model Tool {
  id           String     @id @default(cuid())
  barbershopId String
  name         String
  brand        String?
  acquiredAt   DateTime?
  cost         Decimal?   @db.Decimal(12, 2)
  condition    String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@index([barbershopId, name])
  @@map("tools")
}

model RentAgreement {
  id           String          @id @default(cuid())
  barbershopId String
  barberId     String
  amount       Decimal         @db.Decimal(12, 2)
  periodicity  RentPeriodicity
  dueDay       Int?
  startsAt     DateTime
  endsAt       DateTime?
  status       RentStatus      @default(CURRENT)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  barbershop   Barbershop      @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber       Barber          @relation(fields: [barberId], references: [id], onDelete: Cascade)
  payments     RentPayment[]

  @@index([barbershopId, status])
  @@index([barberId, status])
  @@map("rent_agreements")
}

model RentPayment {
  id              String        @id @default(cuid())
  rentAgreementId String
  paymentId       String        @unique
  dueAt           DateTime
  amountDue       Decimal       @db.Decimal(12, 2)
  amountPaid      Decimal       @default(0) @db.Decimal(12, 2)
  status          RentStatus    @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  agreement       RentAgreement @relation(fields: [rentAgreementId], references: [id], onDelete: Cascade)
  payment         Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([dueAt, status])
  @@map("rent_payments")
}

model NotificationLog {
  id          String              @id @default(cuid())
  bookingId   String?
  channel     NotificationChannel
  recipient   String
  templateKey String
  status      NotificationStatus  @default(PENDING)
  scheduledAt DateTime?
  sentAt      DateTime?
  error       String?
  createdAt   DateTime            @default(now())
  booking     Booking?            @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@map("notification_logs")
}

model AvailabilityBlock {
  id           String                @id @default(cuid())
  barbershopId String
  barberId     String?
  type         AvailabilityBlockType
  startsAt     DateTime
  endsAt       DateTime
  recurrence   String?
  reason       String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  barbershop   Barbershop            @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber       Barber?               @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startsAt])
  @@index([barbershopId, startsAt])
  @@map("availability_blocks")
}
